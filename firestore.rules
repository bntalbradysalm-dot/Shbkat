
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * تم تحديث القواعد للسماح بالوصول الكامل (قراءة وكتابة) لكل المستخدمين المسجلين.
     * هذا يضمن أن الإدارة والمستخدمين يمكنهم الوصول لكافة المجموعات (soldCards, transactions, etc.) دون قيود أمنية حالياً.
     * تم تحديث القواعد لحل مشكلة Permission Denied التي ظهرت عند محاولة جلب مبيعات الكروت.
     * التحديث الأخير لضمان إعادة النشر: FORCE_REDEPLOY_V11_FULL_ACCESS
     */
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
    
    // قواعد صريحة إضافية للمجموعات الحساسة لضمان عدم حدوث تعارض
    match /soldCards/{cardId} {
      allow read, write: if request.auth != null;
    }
    
    match /withdrawalRequests/{reqId} {
      allow read, write: if request.auth != null;
    }
  }
}
