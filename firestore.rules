
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * تم فتح جميع الصلاحيات (القراءة والكتابة) لكل المستخدمين المسجلين.
     * هذا يضمن أن الإدارة والمستخدمين يمكنهم الوصول لكافة المجموعات (soldCards, transactions, etc.) دون قيود أمنية.
     * تم تحديث القواعد لحل مشكلة Permission Denied في لوحة التحكم.
     * تم إضافة هذا التعليق لضمان تحديث القواعد: FORCE_UPDATE_FULL_ACCESS_V10
     */
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
