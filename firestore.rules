
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * وظيفة للتحقق مما إذا كان المستخدم هو مدير النظام
     * الرقم المعتمد: 770326828
     * المعرف الفريد المكتشف: wsy8bUcULSYX2J9Q9WyisiFX5ki2
     */
    function isAdmin() {
      return request.auth != null && 
        (request.auth.token.email == '770326828@shabakat.com' || 
         request.auth.uid == 'wsy8bUcULSYX2J9Q9WyisiFX5ki2');
    }

    /**
     * قاعدة ذهبية: المدير يملك صلاحية القراءة والكتابة على كافة مستندات النظام
     * تم تحسينها لتشمل كافة العمليات (get, list, create, update, delete)
     */
    match /{document=**} {
      allow read, write: if isAdmin();
    }
    
    /**
     * قواعد صريحة لمجموعة الديون (clientDebts)
     * تضمن نجاح عمليات الـ list والـ get والـ write للمدير بشكل مباشر
     */
    match /clientDebts/{debtId} {
      allow read, write: if isAdmin();
    }
    
    /**
     * مبيعات الكروت - قواعد محددة للعملاء والمدير
     */
    match /soldCards/{cardId} {
      allow read, create, update: if request.auth != null;
      allow delete: if isAdmin();
    }
    
    // إدارة الشبكات والوصول للفئات والكروت
    match /networks/{networkId} {
      allow read, write: if request.auth != null;
      
      match /cardCategories/{catId} {
        allow read, write: if request.auth != null;
      }
      
      match /cards/{cardId} {
        allow read, write: if request.auth != null;
      }
    }

    // ملفات المستخدمين وعملياتهم الشخصية
    match /users/{userId} {
      allow read, write: if request.auth != null;
      
      match /transactions/{txId} {
        allow read, write: if request.auth != null;
      }
      
      match /notifications/{notifId} {
        allow read, write: if request.auth != null;
      }
      
      match /favorites/{favId} {
        allow read, write: if request.auth != null;
      }
    }
    
    // الطلبات العامة للنظام
    match /withdrawalRequests/{reqId} {
      allow read, write: if request.auth != null;
    }
    
    match /renewalRequests/{reqId} {
      allow read, write: if request.auth != null;
    }
    
    match /billPaymentRequests/{reqId} {
      allow read, write: if request.auth != null;
    }
    
    match /storeOrders/{orderId} {
      allow read, write: if request.auth != null;
    }
    
    // المنتجات والإعدادات العامة (مفتوحة للقراءة للجميع، الكتابة للمدير ضمناً)
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /advertisements/{adId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /appSettings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /alwadiOptions/{optId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /paymentMethods/{methodId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
